{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CICD-Agent",
  "version": "0.4.1",
  "identifier": "com.cicdagent.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CI/CD Agent",
        "width": 1000,
        "height": 550,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8787 ws://127.0.0.1:8787;"
    }
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "publisher": "Total eBiz Solutions Pte Ltd",
    "copyright": "Copyright (c) 2026 Total eBiz Solutions Pte Ltd",
    "homepage": "https://www.totalebizsolutions.com/",
    "shortDescription": "Local CI/CD automation assistant.",
    "longDescription": "CI/CD Agent is a local-first desktop assistant for repository indexing, pull request preparation, and pipeline automation.",
    "targets": ["msi", "nsis", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/cicd-daemon"],
    "windows": {
      "allowDowngrades": false,
      "nsis": {
        "displayLanguageSelector": false,
        "headerImage": "installer-assets/installer-header.bmp",
        "installMode": "both",
        "installerIcon": "icons/icon.ico",
        "languages": ["English"],
        "sidebarImage": "installer-assets/installer-sidebar.bmp",
        "startMenuFolder": "Total eBiz Solutions",
        "uninstallerIcon": "icons/icon.ico"
      },
      "wix": {
        "upgradeCode": "85E97B81-5039-4096-9BCC-11B117E21101"
      }
    }
  },
  "plugins": {}
}
