{
  "name": "@cicd-agent/daemon",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "cicd-agent-daemon": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bundle": "node scripts/bundle.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/bin.ts",
    "start": "node dist/bin.js",
    "test": "vitest run",
    "lint": "eslint src --ext .ts"
  },
  "pkg": {
    "assets": [
      "node_modules/better-sqlite3/prebuilds/**/*.node",
      "node_modules/better-sqlite3/build/Release/*.node",
      "node_modules/sqlite-vec/prebuilds/**/*.node",
      "node_modules/sqlite-vec/build/Release/*.node",
      "node_modules/web-tree-sitter/**/*.wasm"
    ]
  },
  "dependencies": {
    "@cicd-agent/core": "workspace:*",
    "@fastify/cors": "^10.1.0",
    "@fastify/sensible": "^5.6.0",
    "dotenv": "^16.4.0",
    "fastify": "^4.28.0",
    "fastify-sse-v2": "^4.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@yao-pkg/pkg": "^5.12.0",
    "esbuild": "^0.21.5",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
