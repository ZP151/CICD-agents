{
  "name": "@cicd-agent/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "dev-agent": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
