    "eventsource": "^2.0.2",
    "ink": "^5.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "keytar": "^7.9.0",
    "ora": "^8.0.0",
    "react": "^18.3.0",
    "undici": "^6.19.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.0",
    "ink-testing-library": "^4.0.0",
