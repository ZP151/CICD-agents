# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Azure DevOps
AZURE_DEVOPS_ORG=your-org
AZURE_DEVOPS_PROJECT=your-project
# The PAT itself is NOT stored here. Use:
#   python -m cli.main configure-pat
# which writes the PAT to OS keyring under service "cicd-agent".

# Runtime
RUNTIME_HOST=127.0.0.1
RUNTIME_PORT=8787
RUNTIME_IDLE_TIMEOUT_SEC=1800
RUNTIME_DATA_DIR=
RUNTIME_LOG_LEVEL=INFO

# Planner
PLANNER_MAX_STEPS=12
PLANNER_TOKEN_BUDGET=12000

# Indexer
INDEX_MAX_FILE_BYTES=524288
INDEX_EMBED_BATCH=64

# ── Azure Cloud Persistence (opt-in) ─────────────────────────────────────────
# Requires `az login` (or any DefaultAzureCredential source) on the dev machine.
# When these are set, data is stored per-user in Azure and syncs across machines.
# When unset, the agent falls back to local JSON files (default).

# Azure Storage account name (for Profile persistence via Table Storage)
# AZURE_STORAGE_ACCOUNT=mystorageaccount

# Azure Key Vault URL (for PAT and API key storage)
# AZURE_KEYVAULT_URL=https://my-vault.vault.azure.net/

# Azure Cosmos DB endpoint (for chat session persistence)
# AZURE_COSMOS_ENDPOINT=https://my-cosmos.documents.azure.com:443/

# Cosmos session TTL in seconds (default: 7776000 = 90 days)
# AZURE_COSMOS_SESSION_TTL_SEC=7776000
